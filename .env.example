# PrizmAI Environment Variables Template
# Copy this file to .env and fill in your actual values

# Django Settings
SECRET_KEY=your-long-random-secret-key-here
DEBUG=False
ALLOWED_HOSTS=your-app-id.appspot.com,localhost,127.0.0.1

# Email Configuration (board invitations, password reset, etc.)
# ---------------------------------------------------------------
# To send REAL emails (even during local dev), fill in the two fields below.
# PrizmAI will automatically switch from the console backend to Gmail SMTP.
#
# Gmail setup (takes ~2 minutes):
#   1. Enable 2-Step Verification on your Google account if not already done.
#   2. Go to https://myaccount.google.com/apppasswords
#   3. Create an App Password (App = "Mail", Device = "Other / PrizmAI").
#   4. Copy the 16-character password Google shows you (spaces are optional).
#   5. Paste it as EMAIL_HOST_PASSWORD below — DO NOT use your normal password.
#
# Leave both values empty to keep using the console (terminal) backend.
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-gmail@gmail.com
EMAIL_HOST_PASSWORD=xxxx xxxx xxxx xxxx
DEFAULT_FROM_EMAIL=your-gmail@gmail.com

# Database (for Cloud SQL if needed)
# DATABASE_URL=postgres://username:password@host:port/database_name

# Google Cloud Settings
GOOGLE_CLOUD_PROJECT=your-project-id

# Google OAuth2 Configuration (for "Sign in with Google")
# Get these from Google Cloud Console: https://console.cloud.google.com/
# 1. Create a new project or select existing one
# 2. Enable the Google Identity Services API
# 3. Create OAuth 2.0 credentials
# 4. Add your domain to authorized domains
GOOGLE_OAUTH2_CLIENT_ID=your-google-oauth2-client-id.apps.googleusercontent.com
GOOGLE_OAUTH2_CLIENT_SECRET=your-google-oauth2-client-secret

# Gemini API Key (for AI features)
GEMINI_API_KEY=your-gemini-api-key-here

# OpenAI API Key (platform-level key for OpenAI provider — optional if using BYOK only)
OPENAI_API_KEY=your-openai-api-key-here
# OpenAI model to use (legacy single-model setting — feeds the COMPLEX tier's fallback).
OPENAI_MODEL=gpt-5.6-sol
# Tiered OpenAI model selection (overrides OPENAI_MODEL for each complexity tier).
# GPT-5.6 generation. Confirm exact ids against OpenAI's current model list before prod.
# OPENAI_MODEL_SIMPLE=gpt-5.6-terra    # lightweight tasks: classification, formatting
# OPENAI_MODEL_COMPLEX=gpt-5.6-sol     # heavy tasks: analysis, generation, reasoning
# OPENAI_MODEL_PREMIUM=gpt-5.6-sol     # escape hatch: large-document / long-context

# Anthropic Claude API Key (platform-level key for Anthropic provider — optional if using BYOK only)
ANTHROPIC_API_KEY=your-anthropic-api-key-here
# Anthropic model to use (legacy single-model setting — feeds the COMPLEX tier's fallback).
ANTHROPIC_MODEL=claude-opus-4-8
# Tiered Anthropic model selection (overrides ANTHROPIC_MODEL for each complexity tier).
# Sonnet 5 for light work, Opus 4.8 for heavy + premium (Haiku intentionally not used).
# ANTHROPIC_MODEL_SIMPLE=claude-sonnet-5   # lightweight tasks
# ANTHROPIC_MODEL_COMPLEX=claude-opus-4-8  # heavy tasks
# ANTHROPIC_MODEL_PREMIUM=claude-opus-4-8  # escape hatch: large-document / long-context
# Maximum tokens Anthropic generates per response (SIMPLE-tier default; complex/premium
# use a larger budget internally so large structured-JSON payloads don't truncate).
ANTHROPIC_MAX_TOKENS=2048

# Gemini tiered model selection (optional — defaults shown below).
# simple/complex run on the economical gemini-3.1-flash-lite; gemini-2.5-flash is the
# PREMIUM escape hatch used only for large-document requests. Override any var to revert.
# GEMINI_MODEL_SIMPLE=gemini-3.1-flash-lite
# GEMINI_MODEL_COMPLEX=gemini-3.1-flash-lite
# GEMINI_MODEL_PREMIUM=gemini-2.5-flash
# GEMINI_MODEL_FUNCTION_CALLING=gemini-3.1-flash-lite  # set to gemini-2.5-flash to revert chat actions

# AI Router kill-switch. Set to false to bypass the router and call Gemini directly.
# Use only during production incidents. Default: true (router enabled).
AI_ROUTER_ENABLED=true

# BYOK Encryption Key — AES-256 Fernet key used to encrypt/decrypt user and org BYOK API keys.
# Generate a fresh key with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# IMPORTANT: Keep this value SECRET. Never commit it to version control.
# If this key is lost, all stored BYOK keys become unrecoverable and must be re-entered.
AI_KEY_ENCRYPTION_KEY=your-fernet-key-here

# Redis (required for caching, Celery, and Django Channels in production)
# REDIS_URL=redis://127.0.0.1:6379/0

# PostgreSQL (optional — SQLite is used by default for development)
# DATABASE_URL=postgres://username:password@host:port/database_name

# Web Search for AI Assistant (optional — enables RAG web search)
# GOOGLE_SEARCH_API_KEY=your-google-search-api-key
# GOOGLE_SEARCH_ENGINE_ID=your-search-engine-id
# ENABLE_WEB_SEARCH=True
